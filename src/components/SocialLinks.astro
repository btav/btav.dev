---
import { Icon } from "astro-icon/components";
import { GITHUB_URL, LINKEDIN_URL, BLUESKY_URL, SPOTIFY_URL } from "../consts";
---

<ul>
  <li>
    <a href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
      <Icon name="tabler:brand-github" />
    </a>
  </li>
  <li>
    <a href={LINKEDIN_URL} target="_blank" rel="noopener" aria-label="LinkedIn">
      <Icon name="tabler:brand-linkedin" />
    </a>
  </li>
  <li>
    <a href={BLUESKY_URL} target="_blank" rel="noopener" aria-label="Bluesky">
      <Icon name="tabler:brand-bluesky" />
    </a>
  </li>
  <li>
    <a href={SPOTIFY_URL} target="_blank" rel="noopener" aria-label="Spotify">
      <Icon name="tabler:brand-spotify" />
    </a>
  </li>
</ul>

<style>
  ul {
    all: unset;
    display: flex;
    flex-direction: row;
    align-items: center;
    list-style-type: none;
    gap: 1rem;
    margin: 0;
  }
  a {
    display: inline-flex;
    align-items: center;
    color: var(--link-color);
    text-decoration: none;
    border-radius: 4px;
    transition: color 0.2s ease;
  }
  a:hover {
    color: var(--heading-color);
  }
  [data-icon] {
    width: 1.75rem;
    height: 1.75rem;
  }
</style>
